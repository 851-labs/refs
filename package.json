{
  "name": "@851-labs/refs",
  "version": "0.1.0",
  "description": "Manage shallow git reference repositories in ./references",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "bin": {
    "refs": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "cli": "bun run src/bin.ts",
    "build": "bun build ./src/bin.ts --target=node --outfile=dist/bin.js",
    "check": "tsc --noEmit",
    "lint": "oxlint src test vitest.config.ts",
    "lint:fix": "oxlint --fix src test vitest.config.ts",
    "test": "vitest run",
    "release:cli:check": "bun run check && bun run lint && bun run test && bun run build && node dist/bin.js --help",
    "prepare": "lefthook install",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.83",
    "effect": "4.0.0-beta.83"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "latest",
    "lefthook": "2.1.9",
    "oxlint": "1.69.0",
    "typescript": "latest",
    "vitest": "latest"
  }
}
